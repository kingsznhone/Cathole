@using CatFlapRelay
@using CatFlapRelay.Panel
@using CatFlapRelay.Panel.Components
@using CatFlapRelay.Panel.Components.Layout
@using CatFlapRelay.Panel.Services
@inject RelayService RelayService
@inject NotificationService _notice
@implements IDisposable

<Card Title="@( (Relay.Statistics.IsRunning ? " 🟢 " : " 🔴 ")+Relay.Option.Name)" Style="width: 360px;" Hoverable="true">
    <Extra>
        <Dropdown  Placement="Placement.Bottom" Arrow>
            <ChildContent>
                @if (Relay.Option.DualMode)
                {
                    <Tag Color="TagColor.Blue">Dual Mode</Tag>
                }
                <Tag>...</Tag>
            </ChildContent>
            <Overlay>
                <Menu>
                    <MenuItem>
                        <Button OnClick="Relay.Start"  Style="width:80px">
                            Start
                        </Button>
                    </MenuItem>
                    <MenuItem>
                        <Button OnClick="async () => await Relay.StopAsync()" Style="width:80px">
                            Stop
                        </Button>
                    </MenuItem>
                    <MenuItem>
                        <Button OnClick="OpenEdit"  Style="width:80px">
                            Edit
                        </Button>
                    </MenuItem>
                    <MenuItem>
                        <Button Danger OnClick="DeleteAsync" Style="width:80px">
                            Delete
                        </Button>
                    </MenuItem>
                </Menu>
            </Overlay>
        </Dropdown>
    </Extra>
   <ChildContent>
       @{ var s = _stats; }
       <Flex Direction="FlexDirection.Vertical" Gap="FlexGap.Small">

           <Flex Justify="FlexJustify.SpaceBetween">
               <span style="color: rgba(0,0,0,0.45)">Listen</span>
               <Text Code>@Relay.Option.ListenHost</Text>
           </Flex>
           <Flex Justify="FlexJustify.SpaceBetween">
               <span style="color: rgba(0,0,0,0.45)">Target</span>
               <Text Code>@Relay.Option.TargetHost</Text>
           </Flex>
           <Flex Gap="FlexGap.Small" Align="FlexAlign.Center">
               @if (Relay.Option.TCP)
               {
                   <Tag>TCP</Tag>
               }
               @if (Relay.Option.UDP)
               {
                   <Tag>UDP</Tag>
               }
               <span style="color: rgba(0,0,0,0.45); margin-left: auto">Buffer: @FormatBytes(Relay.Option.BufferSize)</span>
           </Flex>

           <Divider Style="margin: 4px 0;" />

           <Flex Justify="FlexJustify.SpaceBetween">
               <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center">
                   <span style="font-size:12px; color: rgba(0,0,0,0.45)">TCP Active</span>
                   <Text Strong>@s.TcpActiveConnections</Text>
               </Flex>
               <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center">
                   <span style="font-size:12px; color: rgba(0,0,0,0.45)">TCP Total</span>
                   <Text Strong>@s.TcpTotalConnections</Text>
               </Flex>
               @if (Relay.Option.UDP)
               {
                   <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center">
                       <span style="font-size:12px; color: rgba(0,0,0,0.45)">UDP Tunnels</span>
                       <Text Strong>@s.UdpActiveTunnels</Text>
                   </Flex>
               }
               <Flex Direction="FlexDirection.Vertical" Align="FlexAlign.Center">
                   <span style="font-size:12px; color: rgba(0,0,0,0.45)">Errors</span>
                   <Text Strong Style="@(s.ConnectionErrors > 0 ? "color:#ff4d4f" : "")">@s.ConnectionErrors</Text>
               </Flex>
           </Flex>

           <Divider Style="margin: 4px 0;" />

           <Flex Justify="FlexJustify.SpaceBetween">
               <span style="color: rgba(0,0,0,0.45)">↑ @FormatBytes(s.TcpBytesSent + s.UdpBytesSent)</span>
               <span style="color: rgba(0,0,0,0.45)">↓ @FormatBytes(s.TcpBytesReceived + s.UdpBytesReceived)</span>
               @if (s.IsRunning)
               {
                   <span style="color: rgba(0,0,0,0.45)">⏱ @FormatUptime(s.Uptime)</span>
               }
           </Flex>

       </Flex>
   </ChildContent>
</Card>

<RelayOptionModal @ref="_editModalRef" Option="_editOption" IsEdit="true" />

@code {
    [Parameter]
    public FlapRelay Relay { get; set; }

    private RelayOptionModal? _editModalRef;
    private FlapRelayOption _editOption = new();
    private FlapRelayStatistics _stats = new();
    private CancellationTokenSource _refreshCts = new();

    protected override void OnInitialized()
    {
        _stats = Relay.Statistics;
        _ = RefreshLoopAsync(_refreshCts.Token);
    }

    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                _stats = Relay.Statistics;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _refreshCts.Cancel();
        _refreshCts.Dispose();
    }

    private void OpenEdit()
    {
        _editOption = new FlapRelayOption
        {
            Id = Relay.Option.Id,
            Name = Relay.Option.Name,
            ListenHost = Relay.Option.ListenHost,
            TargetHost = Relay.Option.TargetHost,
            TCP = Relay.Option.TCP,
            UDP = Relay.Option.UDP,
            BufferSize = Relay.Option.BufferSize,
            SocketTimeout = Relay.Option.SocketTimeout,
            UdpTunnelTimeout = Relay.Option.UdpTunnelTimeout
        };
        _editModalRef?.Show();
    }

    private async Task DeleteAsync()
    {
        try
        {
            await RelayService.RemoveRelayAsync(Relay.Option.Id);
        }
        catch (Exception ex)
        {
            _ = _notice.Warning(new NotificationConfig()
            {
                Message = "Delete relay failed",
                Description = ex.Message
            });
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024 * 1024):F1} GB",
        >= 1024 * 1024         => $"{bytes / (1024.0 * 1024):F1} MB",
        >= 1024                => $"{bytes / 1024.0:F1} KB",
        _                      => $"{bytes} B"
    };

    private static string FormatUptime(TimeSpan uptime) =>
        uptime.TotalHours switch
        {
            >= 24 => $"{uptime.Days:D2}:{uptime.Hours:D2}:{uptime.Minutes:D2}:{uptime.Seconds:D2}",
            _ => $"{uptime.Days:D2}:{uptime.Hours:D2}:{uptime.Minutes:D2}:{uptime.Seconds:D2}"
        };
}
